		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "manf-pipeline"
		},
		"AzureSqlDatabase1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase1'"
		},
		"LocalSQLEXPRESS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LocalSQLEXPRESS'"
		},
		"AzureSqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "khosyi-leanflow.database.windows.net"
		},
		"AzureSqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "leanflow"
		},
		"AzureSqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"LocalSQLEXPRESS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost,1433"
		},
		"LocalSQLEXPRESS_properties_typeProperties_database": {
